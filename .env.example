# Copy to .env and fill in values. Never commit real .env.

NODE_ENV=development
PORT=5000
BASE_URL=/api
DBCONNECTIONURL=mongodb+srv://USER:PASS@cluster.example.mongodb.net/dbname

# Required in production (min 32 characters each). In development, legacy defaults apply if unset.
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_REFRESH_SECRET=optional-second-long-secret-for-refresh-tokens

# CORS in server.js reflects any request origin (not whitelist). ALLOWED_ORIGINS is unused; omit or remove.
# FRONTEND_URL is used for onboarding/email login links (schoolOnboarding, staff onboarding, etc.).
FRONTEND_URL=http://localhost:3000

LOG_LEVEL=info
RATE_LIMIT_MAX=100
